namespace app.main

func render(d: any<TextRepresentable>) -> text
    return d.to_text()
end

func main() -> int
    const a: any<TextRepresentable> = "hello"
    const b: any<TextRepresentable> = "world"
    if render(a) != "hello"
        return 1
    end
    if render(b) != "world"
        return 2
    end
    return 0
end
