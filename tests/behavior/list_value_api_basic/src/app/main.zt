namespace app.main

import std.list as list

func main() -> result<void, core.Error>
    const values: list<int> = [2, 4, 6]
    const appended: list<int> = list.append(values, 8)
    const prepended: list<int> = list.prepend(values, 1)
    const reversed: list<int> = list.reverse(values)
    const joined: list<int> = list.concat(prepended, appended)
    const set_values: list<int> = list.set(values, 1, 40)?
    const removed_first: list<int> = list.remove_first(values)?
    const removed_last: list<int> = list.remove_last(values)?
    const removed_at: list<int> = list.remove_at(values, 1)?
    const sliced: list<int> = list.slice(values, 1, 2)?

    if len(values) != 3
        return error("list.append/prepend must keep source list unchanged")
    end
    if len(appended) != 4 or appended[3] != 8
        return error("list.append should add value at end")
    end
    if len(prepended) != 4 or prepended[0] != 1
        return error("list.prepend should add value at start")
    end
    if list.contains(values, 4) == false or list.contains(values, 9)
        return error("list.contains should use element equality")
    end
    if reversed[0] != 6 or reversed[2] != 2
        return error("list.reverse should reverse order")
    end
    if len(joined) != 8 or joined[0] != 1 or joined[7] != 8
        return error("list.concat should join two lists")
    end
    if list.index_of(values, 6).or(-1) != 2 or list.index_of(values, 9).or(-1) != -1
        return error("list.index_of should return optional index")
    end
    if set_values[1] != 40 or values[1] != 4
        return error("list.set should return changed copy")
    end
    if len(removed_first) != 2 or removed_first[0] != 4
        return error("list.remove_first should remove first item")
    end
    if len(removed_last) != 2 or removed_last[1] != 4
        return error("list.remove_last should remove last item")
    end
    if len(removed_at) != 2 or removed_at[1] != 6
        return error("list.remove_at should remove selected item")
    end
    if len(sliced) != 2 or sliced[0] != 4 or sliced[1] != 6
        return error("list.slice should return selected range")
    end

    const words: list<text> = ["zen", "lang"]
    const words_more: list<text> = list.append(words, "v1")
    const words_rev: list<text> = list.reverse(words_more)
    const words_set: list<text> = list.set(words_more, 1, "compiler")?
    var fallback: text = ""

    if list.contains(words_more, "v1") == false
        return error("list.contains should work for text")
    end
    if list.index_of(words_more, "lang").or(-1) != 1
        return error("list.index_of should work for text")
    end
    if len(list.first(words_rev).or(fallback)) != 2
        return error("list.reverse should work for text")
    end
    if len(words_set[1]) != 8 or len(words_more[1]) != 4
        return error("list.set should copy text lists")
    end

    return success()
end
