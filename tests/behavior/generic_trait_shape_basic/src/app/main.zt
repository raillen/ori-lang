namespace app.main

trait BoxLike<T>
    func get() -> T
end

struct IntBox
    value: int
end

apply BoxLike<int> to IntBox
    func get() -> int
        return self.value
    end
end

func main() -> int
    const box: IntBox = IntBox(value: 9)
    if box.get() != 9
        return 1
    end
    return 0
end
