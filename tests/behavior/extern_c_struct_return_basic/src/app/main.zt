namespace app.main

attr repr("c")
struct Point
    x: int
    y: int
end

extern c
    attr name("zt_ffi_make_point")
    func make_point(x: int, y: int) -> Point
end

public func main() -> int
    const point: Point = make_point(20, 22)
    if point.x + point.y != 42
        return 1
    end
    return 0
end
