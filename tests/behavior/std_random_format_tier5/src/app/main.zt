namespace app.main

import std.format as format
import std.random as random

struct Label
    name: text
    count: int
end

func main() -> result<void, core.Error>
    random.seed(2026)

    const picked: float = random.float_between(1.0, 2.0)?
    if picked < 1.0 or picked > 2.0
        return error("random.float_between should stay inside range")
    end

    const values: list<int> = [4, 5, 6]
    const choice: int = random.choice(values).or(0)
    if choice < 4 or choice > 6
        return error("random.choice should return item from list")
    end

    const shuffled: list<int> = random.shuffle(values)
    if len(shuffled) != 3
        return error("random.shuffle should preserve list size")
    end

    const names: list<text> = ["alpha", "beta", "gamma"]
    const name_choice: optional<text> = random.choice(names)
    if name_choice.is_none()
        return error("random.choice should preserve text element type")
    end

    const shuffled_names: list<text> = random.shuffle(names)
    if len(shuffled_names) != 3
        return error("random.shuffle should preserve text list size")
    end

    if format.pretty(42) != "42"
        return error("format.pretty should use TextRepresentable")
    end
    if format.compact(true) != "true"
        return error("format.compact should support bool")
    end
    if format.as_json("ok") != "\"ok\""
        return error("format.as_json should quote rendered text")
    end
    if format.yaml(5) != "value: 5"
        return error("format.yaml should prefix rendered text")
    end

    const rows: list<any<TextRepresentable>> = [1, true, "ok"]
    if len(format.table(rows)) == 0 or len(format.csv(rows)) == 0
        return error("format table/csv should render dynamic TextRepresentable rows")
    end

    const rendered_label: text = to_text(Label(name: "alpha", count: 2))
    if len(rendered_label) == 0
        return error("TextRepresentable auto-derive should render user structs")
    end

    return success()
end
