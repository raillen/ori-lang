namespace app.main

func pair(label: text, value: int) -> tuple<text, int>
    return (label, value)
end

func count_pairs(entries: list<tuple<text, int>>) -> int
    return len(entries)
end

func main() -> int
    const direct: tuple<text, int> = ("score", 10)
    const produced: tuple<text, int> = pair("level", 2)
    var entries: list<tuple<text, int>> = [
        direct,
        produced,
        ("bonus", 5),
    ]

    if count_pairs(entries) != 3
        return 1
    end

    entries[1] = ("stage", 4)

    if len(entries) != 3
        return 2
    end

    return 0
end
