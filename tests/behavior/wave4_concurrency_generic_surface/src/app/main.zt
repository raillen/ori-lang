namespace app.main

import std.atomic as atomic
import std.channels as channels
import std.jobs as jobs
import std.shared as shared

func base_job() -> int
    return 20
end

func add_one(value: int) -> int
    return value + 1
end

public func main() -> int
    const plain: jobs.Job<int> = jobs.spawn(base_job)
    if jobs.join(plain) != 20
        return 1
    end

    const with_value: jobs.Job<int> = jobs.spawn(add_one, 41)
    if jobs.join(with_value) != 42
        return 2
    end

    const channel: channels.Channel<int> = channels.create()
    channels.send(channel, 7)
    const received: optional<int> = channels.receive(channel)
    if received.is_none() or received.or(0) != 7
        return 3
    end
    channels.close(channel)

    const shared_value: shared.Shared<int> = shared.create(3)
    if shared.get(shared_value) != 3
        return 4
    end
    shared.set(shared_value, 5)
    if shared.get(shared_value) != 5
        return 5
    end

    const counter: atomic.Atomic<int> = atomic.create(10)
    if atomic.load(counter) != 10
        return 6
    end
    if atomic.add(counter, 4) != 14
        return 7
    end
    if atomic.store(counter, 1) != 1
        return 8
    end
    if atomic.load(counter) != 1
        return 9
    end

    return 0
end
