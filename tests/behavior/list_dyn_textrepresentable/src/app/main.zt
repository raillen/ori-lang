namespace app.main

import std.io as io

-- E2E for R3.M4 any dispatch minimum subset: heterogeneous collection.
-- The official subset is any<TextRepresentable> only; this test verifies:
--   - dispatch via to_text() on any<TextRepresentable> values;
--   - runtime helper: zt_dyn_text_repr_to_text.

func main() -> int
    -- Create a any<TextRepresentable> from text (supported boxing)
    const d: any<TextRepresentable> = "hello"
    
    -- Test dispatch: any<TextRepresentable> must expose to_text()
    const txt: text = d.to_text()
    
    if txt != "hello"
        return 1
    end
    
    return 0
end
