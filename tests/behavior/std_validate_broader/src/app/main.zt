namespace app.main

import std.validate as validate

func maybe_score(ok: bool) -> optional<int>
    if ok
        return 7
    end
    return none
end

func maybe_ratio(ok: bool) -> optional<float>
    if ok
        return 1.25
    end
    return none
end

func maybe_flag(ok: bool) -> optional<bool>
    if ok
        return true
    end
    return none
end

func parse_score(ok: bool) -> result<int, text>
    if ok
        return success(7)
    end
    return error("invalid score")
end

func main() -> int
    const names: list<text> = ["Zenith", "Nova"]
    const empty_names: list<text> = []
    const flags: list<bool> = [true, false]
    const ratios: list<float> = [0.5, 1.25, 2.0]
    const key_core: text = "core"
    const key_docs: text = "docs"
    const scores: map<text, int> = { key_core: 7, key_docs: 8 }
    const empty_scores: map<text, int> = {}
    const id_core: int = 1
    const id_docs: int = 2
    const label_core: text = "core"
    const label_docs: text = "docs"
    const names_by_id: map<int, text> = { id_core: label_core, id_docs: label_docs }
    const empty_names_by_id: map<int, text> = {}
    const present_score: optional<int> = maybe_score(true)
    const missing_score: optional<int> = maybe_score(false)
    const present_ratio: optional<float> = maybe_ratio(true)
    const missing_ratio: optional<float> = maybe_ratio(false)
    const present_flag: optional<bool> = maybe_flag(true)
    const missing_flag: optional<bool> = maybe_flag(false)
    const parsed_score: result<int, text> = parse_score(true)
    const failed_score: result<int, text> = parse_score(false)

    if validate.between_float(1.25, min: 1.0, max: 2.0) == false
        return 1
    end
    if validate.between_float(0.5, min: 1.0, max: 2.0)
        return 2
    end
    if validate.positive_float(0.25) == false or validate.positive_float(0.0)
        return 3
    end
    if validate.non_negative_float(0.0) == false or validate.negative_float(-0.5) == false
        return 4
    end
    if validate.non_zero_float(1.0) == false or validate.non_zero_float(0.0)
        return 5
    end
    if validate.one_of_float(1.25, ratios) == false or validate.one_of_float(3.0, ratios)
        return 6
    end

    if validate.is_true(true) == false or validate.is_true(false)
        return 10
    end
    if validate.is_false(false) == false or validate.is_false(true)
        return 11
    end
    if validate.one_of_bool(false, flags) == false
        return 12
    end

    if validate.is_some_int(present_score) == false or validate.is_none_int(present_score)
        return 20
    end
    if validate.is_none_int(missing_score) == false or validate.is_some_int(missing_score)
        return 21
    end
    if validate.is_some_float(present_ratio) == false or validate.is_none_float(present_ratio)
        return 22
    end
    if validate.is_none_float(missing_ratio) == false or validate.is_some_float(missing_ratio)
        return 23
    end
    if validate.is_some_bool(present_flag) == false or validate.is_none_bool(present_flag)
        return 24
    end
    if validate.is_none_bool(missing_flag) == false or validate.is_some_bool(missing_flag)
        return 25
    end
    if validate.is_success_int_text(parsed_score) == false or validate.is_error_int_text(parsed_score)
        return 26
    end
    if validate.is_error_int_text(failed_score) == false or validate.is_success_int_text(failed_score)
        return 27
    end

    if validate.not_empty_list_text(names) == false or validate.not_empty_list_text(empty_names)
        return 30
    end
    if validate.min_length_list_text(names, 2) == false or validate.min_length_list_text(names, 3)
        return 31
    end
    if validate.max_length_list_text(names, 2) == false or validate.max_length_list_text(names, 1)
        return 32
    end
    if validate.length_between_list_text(names, min: 1, max: 2) == false
        return 33
    end

    if validate.not_empty_map_text_int(scores) == false or validate.not_empty_map_text_int(empty_scores)
        return 40
    end
    if validate.min_size_map_text_int(scores, 2) == false or validate.min_size_map_text_int(scores, 3)
        return 41
    end
    if validate.max_size_map_text_int(scores, 2) == false or validate.max_size_map_text_int(scores, 1)
        return 42
    end
    if validate.size_between_map_text_int(scores, min: 1, max: 2) == false
        return 43
    end
    if validate.not_empty_map_int_text(names_by_id) == false or validate.not_empty_map_int_text(empty_names_by_id)
        return 44
    end
    if validate.size_between_map_int_text(names_by_id, min: 2, max: 2) == false
        return 45
    end

    return 0
end
