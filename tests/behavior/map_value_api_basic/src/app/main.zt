namespace app.main

import std.list as list
import std.map as map

func main() -> result<void, core.Error>
    const key_mode: text = "mode"
    const key_theme: text = "theme"
    const key_profile: text = "profile"
    const key_missing: text = "missing"
    const key_extra: text = "extra"
    const value_debug: text = "debug"
    const value_dark: text = "dark"
    const value_dev: text = "dev"
    const value_release: text = "release"
    const value_yes: text = "yes"
    const empty_text: text = ""

    const base: map<text, text> = { key_mode: value_debug, key_theme: value_dark }

    const added: map<text, text> = map.set(base, key_profile, value_dev)
    if len(base) != 2 or len(added) != 3
        return error("map.set should return a new map and keep the original length")
    end

    if map.contains(added, key_profile) == false or map.has_key(added, key_profile) == false
        return error("map.contains and map.has_key should find inserted keys")
    end
    if len(map.get(added, key_mode).or(empty_text)) != 5
        return error("map.get should return optional value for present key")
    end
    if map.get(added, key_missing).is_some()
        return error("map.get should return none for missing key")
    end

    const removed: map<text, text> = map.remove(added, key_theme)
    if len(removed) != 2 or map.contains(removed, key_theme)
        return error("map.remove should drop a present key")
    end
    if len(added) != 3
        return error("map.remove should not mutate the source map")
    end

    const keys: list<text> = map.keys(removed)
    const values: list<text> = map.values(removed)
    if len(keys) != 2 or len(values) != 2
        return error("map.keys and map.values should preserve entry count")
    end
    if list.contains(keys, key_mode) == false or list.contains(keys, key_profile) == false
        return error("map.keys should expose map keys")
    end
    if list.contains(values, value_debug) == false or list.contains(values, value_dev) == false
        return error("map.values should expose map values")
    end

    const override: map<text, text> = { key_mode: value_release, key_extra: value_yes }
    const merged: map<text, text> = map.merge(base, override)
    if len(merged) != 3
        return error("map.merge should include left and right entries")
    end
    if len(map.get(merged, key_mode).or(empty_text)) != 7
        return error("map.merge should let right map override duplicate keys")
    end

    return success()
end
