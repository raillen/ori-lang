namespace app.main

import std.mem as mem

struct Bag
    values: list<text>
end

func main() -> int
    const values: list<text> = ["one", "two"]
    const unsafe_tuple: tuple<int, list<text>> = (1, values)
    const copied: tuple<int, list<text>> = mem.edit(unsafe_tuple)
    return len(copied.1)
end
