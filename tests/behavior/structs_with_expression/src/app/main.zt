namespace app.main

struct Point
    x: int
    y: int
    z: int
end

public func main() -> int 
    const p1: Point = Point(x: 1, y: 2, z: 3)
    const p2: Point = p1 with x: 10
    if p2.x != 10 
        panic("with single-override: x not updated")
    end
    if p2.y != 2 
        panic("with single-override: y leaked")
    end
    if p2.z != 3 
        panic("with single-override: z leaked")
    end
    const p3: Point = p1 with x: 100, z: 300
    if p3.x != 100 
        panic("with multi-override: x not updated")
    end
    if p3.y != 2 
        panic("with multi-override: y leaked")
    end
    if p3.z != 300 
        panic("with multi-override: z not updated")
    end
    if p1.x != 1 
        panic("with: source mutated x")
    end
    if p1.y != 2 
        panic("with: source mutated y")
    end
    if p1.z != 3 
        panic("with: source mutated z")
    end
    const p4: Point = p1 with y: p1.y + 100
    if p4.x != 1 
        panic("with computed override: x leaked")
    end
    if p4.y != 102 
        panic("with computed override: y wrong")
    end
    if p4.z != 3 
        panic("with computed override: z leaked")
    end
    return 0
end
