namespace app.main

import std.list as list

func bool_key(value: bool) -> int
    if value
        return 1
    end
    return 0
end

func main() -> int
    const values: list<bool> = [true, false, true]
    const flipped: list<bool> = list.map(values, func(value: bool) => value == false)
    const trues: list<bool> = list.filter(values, func(value: bool) => value)
    const found: optional<bool> = list.find(values, func(value: bool) => value == false)
    const sorted: list<bool> = list.sort_by(values, bool_key)

    if len(flipped) != 3 or flipped[0] or flipped[1] == false
        return 1
    end
    if len(trues) != 2 or trues[0] == false or trues[1] == false
        return 2
    end
    if found.is_some() == false
        return 3
    end
    if list.any(values, func(value: bool) => value == false) == false
        return 4
    end
    if list.all(values, func(value: bool) => value)
        return 5
    end
    if list.count(values, func(value: bool) => value) != 2
        return 6
    end
    if sorted[0] or sorted[1] == false or sorted[2] == false
        return 7
    end

    return 0
end
