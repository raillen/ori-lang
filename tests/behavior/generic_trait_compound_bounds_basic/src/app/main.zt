namespace app.main

trait OrderedBox<T> where T is Addable and T is Comparable
    func get() -> T
end

struct IntBox
    value: int
end

apply OrderedBox<int> to IntBox
    func get() -> int
        return self.value
    end
end

func main() -> int
    const box: IntBox = IntBox(value: 5)
    if box.get() != 5
        return 1
    end
    return 0
end
