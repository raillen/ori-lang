namespace app.main

struct Score
    value: int
end

apply Addable to Score
    func add(other: Score) -> Score 
        return Score(value: self.value + other.value)
    end
end

apply Subtractable to Score
    func subtract(other: Score) -> Score 
        return Score(value: self.value - other.value)
    end
end

apply Comparable to Score
    func less(other: Score) -> bool 
        return self.value < other.value
    end
    func less_or_equal(other: Score) -> bool 
        return self.value <= other.value
    end
    func greater(other: Score) -> bool 
        return self.value > other.value
    end
    func greater_or_equal(other: Score) -> bool 
        return self.value >= other.value
    end
end

func main() -> int 
    const left: Score = Score(value: 10)
    const right: Score = Score(value: 3)
    const added: Score = left + right
    const subtracted: Score = left - right
    if not (added > subtracted and subtracted >= right and right < left and right <= subtracted)
        return 1
    end
    return 0
end
