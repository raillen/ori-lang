namespace app.main

import std.io as io

func write_greeting() -> result<void, io.Error>
    io.write("Hello from std.io!")?
    io.write("\n")?

    io.print("Stderr outputs correctly.", to: io.stderr)?
    io.print("\n", to: io.stderr)?

    return success()
end

func main() -> result<void, core.Error>
    match write_greeting()
        case success() ->
            return success()
        case error(err) ->
            const core_err: core.Error = io.to_core_error(err)
            return error(core_err)
    end
end
