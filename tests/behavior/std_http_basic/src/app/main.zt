namespace app.main

import std.http as http

func probe_http() -> result<void, http.Error>
    const get_response: http.Response = http.get("http://127.0.0.1:41235/hello")?

    if get_response.status != 200
        return error(http.Error(kind: http.ErrorKind.InvalidResponse, message: "unexpected status"))
    end

    if get_response.body != "hello from std.http"
        return error(http.Error(kind: http.ErrorKind.InvalidResponse, message: "unexpected body"))
    end

    const post_response: http.Response = http.post("http://127.0.0.1:41235/echo", "zenith", "text/plain")?

    if post_response.status != 200
        return error(http.Error(kind: http.ErrorKind.InvalidResponse, message: "unexpected post status"))
    end

    if post_response.body != "post echo: zenith"
        return error(http.Error(kind: http.ErrorKind.InvalidResponse, message: "unexpected post body"))
    end

    return success()
end

func main() -> result<void, core.Error>
    match probe_http()
        case success() ->
            return success()
        case error(err) ->
            return error("http error")
    end
end
