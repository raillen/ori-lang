namespace app.main

import std.atomic as atomic
import std.channels as channels
import std.jobs as jobs
import std.shared as shared

func base_job() -> int
    return 21
end

func double_value(value: int) -> int
    return value * 2
end

public func main() -> int
    const plain_handle: jobs.Job<int> = jobs.spawn(base_job)
    if jobs.join(plain_handle) != 21
        return 1
    end

    const value_handle: jobs.Job<int> = jobs.spawn(double_value, 21)
    if jobs.join(value_handle) != 42
        return 2
    end

    const channel: channels.Channel<int> = channels.create()
    if channels.receive(channel).is_some()
        return 3
    end
    channels.send(channel, 42)
    const received: optional<int> = channels.receive(channel)
    if received.is_none() or received.or(0) != 42
        return 4
    end
    channels.close(channel)

    const shared_value: shared.Shared<int> = shared.create(7)
    if shared.get(shared_value) != 7
        return 5
    end
    shared.set(shared_value, 11)
    if shared.get(shared_value) != 11
        return 6
    end

    const counter: atomic.Atomic<int> = atomic.create(10)
    if atomic.load(counter) != 10
        return 7
    end
    if atomic.add(counter, 5) != 15
        return 8
    end
    if atomic.store(counter, 2) != 2
        return 9
    end
    if atomic.load(counter) != 2
        return 10
    end

    return 0
end
