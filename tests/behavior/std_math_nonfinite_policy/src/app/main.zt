namespace app.main

import std.float as float
import std.math as math
import std.text as text

func main() -> int
    const nan_value: float = math.nan()
    const infinity_value: float = math.infinity()
    const negative_infinity: float = 0.0 - math.infinity()

    const construction_ok: bool =
        math.is_nan(nan_value) and
        math.is_infinite(infinity_value) and
        math.is_infinite(negative_infinity) and
        math.is_finite(nan_value) == false and
        math.is_finite(infinity_value) == false and
        math.is_finite(12.5)

    const equality_ok: bool =
        (nan_value == nan_value) == false and
        nan_value != nan_value and
        infinity_value == math.infinity()

    const ordering_ok: bool =
        infinity_value > 1.0 and
        negative_infinity < -1.0

    const nan_text: text = float.to_text(nan_value)
    const infinity_text: text = float.to_text(infinity_value)
    const formatting_ok: bool =
        text.contains(nan_text, "nan") and
        text.contains(infinity_text, "inf")

    if construction_ok and equality_ok and ordering_ok and formatting_ok
        return 0
    end

    return 1
end
