namespace app.main

import std.debug as debug

struct Record
    name: text
    count: int
end

enum Shape
    Point
    Circle(radius: int)
end

func main() -> int
    const text_size: int = debug.size_of("hello")
    const int_size: int = debug.size_of(42)
    const bool_size: int = debug.size_of(true)
    const pair: tuple<text, int> = ("score", 10)
    const pair_size: int = debug.size_of(pair)
    const pair_type: text = debug.type_name(pair)
    const record: Record = Record(name: "counter", count: 3)
    const record_size: int = debug.size_of(record)
    const point: Shape = Shape.Point
    const point_size: int = debug.size_of(point)
    const ids: list<int> = [1, 2, 3]
    const ids_size: int = debug.size_of(ids)
    const key: text = "mode"
    const value: text = "debug"
    const tags: map<text, text> = { key: value }
    const tags_size: int = debug.size_of(tags)
    const display: any<TextRepresentable> = "hello"
    const display_size: int = debug.size_of(display)
    const list_type: text = debug.type_name(ids)
    const map_type: text = debug.type_name(tags)
    const any_type: text = debug.type_name(display)

    if text_size <= 0
        return 1
    end

    if int_size != 8
        return 2
    end

    if bool_size != 1
        return 3
    end

    if pair_size != 16
        return 4
    end

    if pair_type != "tuple<text, int>"
        return 5
    end
    if record_size <= 0
        return 6
    end
    if point_size <= 0
        return 7
    end
    if ids_size <= 0
        return 8
    end
    if tags_size <= 0
        return 9
    end
    if display_size <= 0
        return 10
    end
    if list_type != "list<int>"
        return 11
    end
    if map_type != "map<text, text>"
        return 12
    end
    if any_type != "any<TextRepresentable>"
        return 13
    end

    return 0
end
