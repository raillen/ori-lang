namespace app.main

import std.bytes as bytes

func main() -> int
    const max_u8: u8 = 255

    if max_u8 != 255
        return 10
    end

    const near_max: int = 9223372036854775807
    const near_min: int = -9223372036854775807
    if near_max < 0 or near_min > 0
        return 12
    end

    const empty_text: text = ""
    const empty_list: list<int> = [ ]
    const empty_map: map<text, int> = { }
    const empty_bytes: bytes = bytes.empty()

    if len(empty_text) != 0
        return 13
    end
    if len(empty_list) != 0 or len(empty_map) != 0
        return 14
    end
    if len(empty_bytes) != 0
        return 15
    end

    return 0
end
