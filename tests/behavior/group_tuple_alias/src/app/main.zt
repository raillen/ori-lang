namespace app.main

func make_entry(label: text, value: int) -> tuple<text, int>
    return (label, value)
end

func count_entries(entries: list<tuple<text, int>>) -> int
    return len(entries)
end

func main() -> int
    const direct: tuple<text, int> = ("score", 10)
    const produced: tuple<text, int> = make_entry("level", 2)
    var entries: list<tuple<text, int>> = [
        direct,
        produced,
        ("bonus", 5),
    ]

    if count_entries(entries) != 3
        return 1
    end

    entries[1] = ("stage", 4)

    if len(entries) != 3
        return 2
    end

    return 0
end
