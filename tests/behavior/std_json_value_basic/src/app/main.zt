namespace app.main

import std.json as json

func kind_score(kind: json.Kind) -> int
    match kind
        case json.Kind.Null:
            return 0
        case json.Kind.Bool:
            return 1
        case json.Kind.Number:
            return 2
        case json.Kind.Text:
            return 3
        case json.Kind.Array:
            return 4
        case json.Kind.Object:
            return 5
    end
end

func main() -> result<void, core.Error>
    const empty_text: text = ""
    const root: json.Value = json.parse_value("{\"name\":\"Zenith\",\"enabled\":true,\"items\":[1,2,{\"tag\":\"ok\"}]}")?

    if kind_score(json.kind(root)) != 5
        return error("json value kind should detect object")
    end
    if json.len(root) != 3
        return error("json object length should count keys")
    end

    const name_value: json.Value = json.get(root, "name").or(json.Value(raw: "null"))
    if name_value.raw != "\"Zenith\""
        return error(name_value.raw)
    end
    if json.as_text(name_value).or(empty_text) != "Zenith"
        return error("json.get + as_text should read object text")
    end

    const enabled_value: json.Value = json.get(root, "enabled").or(json.Value(raw: "false"))
    if json.as_bool(enabled_value).or(false) == false
        return error("json.as_bool should read true")
    end

    const items_value: json.Value = json.get(root, "items").or(json.Value(raw: "[]"))
    if kind_score(json.kind(items_value)) != 4 or json.len(items_value) != 3
        return error("json array should expose kind and length")
    end

    const first_item: json.Value = json.at(items_value, 0).or(json.Value(raw: "0"))
    if json.as_int(first_item).or(0) != 1
        return error("json.at + as_int should read array item")
    end

    return success()
end
