namespace app.main

func identity<T>(value: T) -> T
    return value
end

func choose<T>(left: T, right: T) -> T
    return left
end

func main() -> int
    const label: text = identity("ok")
    const picked: text = choose(label, "fallback")

    if label != "ok"
        return 1
    end
    if picked != "ok"
        return 2
    end

    return 0
end
