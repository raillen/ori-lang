namespace app.main

import std.set as set

struct Flag
    enabled: bool
    weight: int
end

func main() -> int
    var flags: set<Flag> = set.empty()
    const first: Flag = Flag(enabled: true, weight: 3)
    const same: Flag = Flag(enabled: true, weight: 3)
    const other: Flag = Flag(enabled: false, weight: 3)

    set.add(flags, first)

    if set.len(flags) != 1
        return 1
    end
    if set.has(flags, same) == false
        return 2
    end
    if set.has(flags, other)
        return 3
    end

    set.remove(flags, same)
    if set.len(flags) != 0
        return 4
    end

    return 0
end
