namespace app.main

struct Score
    value: int
end

func multiply(left: Score, right: Score) -> Score
    const product: Score = left * right
    return product
end

func divide(left: Score, right: Score) -> Score
    const quotient: Score = left / right
    return quotient
end

func remainder(left: Score, right: Score) -> Score
    const rem: Score = left % right
    return rem
end

func main() -> int
    const left: Score = Score(value: 6)
    const right: Score = Score(value: 3)
    const product: Score = multiply(left, right)
    const quotient: Score = divide(left, right)
    const rem: Score = remainder(left, right)
    return product.value + quotient.value + rem.value
end
