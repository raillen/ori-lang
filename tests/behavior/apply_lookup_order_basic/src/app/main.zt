namespace app.main

trait Labelled
    func label() -> int
        return 1
    end
end

struct Item
    value: int
end

apply Item
    func label() -> int
        return 2
    end
end

apply Labelled to Item
    func label() -> int
        return 3
    end
end

func main() -> int
    const item: Item = Item(value: 0)
    if item.label() != 2
        return 1
    end
    return 0
end
