namespace app.main

struct Counter
    value: int
end

apply Counter
    mut func increment()
        self.value = self.value + 1
    end
end

func main() -> int
    var score: int = 0
    score = score + 5
    score = score * 2

    var items: list<int> = [1, 2, 3]
    items[0] = 9

    var c: Counter = Counter(value: 0)
    c.increment()
    c.increment()

    if score != 10
        return 1
    end
    if items[0] != 9
        return 2
    end
    if c.value != 2
        return 3
    end
    return 0
end
