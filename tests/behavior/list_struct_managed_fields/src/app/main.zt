namespace app.main

struct Person
    name: text
    age: int
end

func main() -> int
    var people: list<Person> = [
        Person(name: "Alice", age: 30),
        Person(name: "Bob", age: 25),
    ]

    if len(people) != 2
        return 1
    end

    if people[0].name != "Alice"
        return 2
    end

    if people[1].age != 25
        return 3
    end

    return 0
end
