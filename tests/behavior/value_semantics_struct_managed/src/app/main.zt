namespace app.main

struct Bag
    nums: list<int>
end

struct Config
    props: map<text, text>
end

func main() -> int
    var a: Bag = Bag(nums: [1, 2, 3])
    var b: Bag = a
    b.nums[1] = 9

    const list_score: int = (a.nums[1] * 10) + b.nums[1]

    const key_mode: text = "mode"
    const key_theme: text = "theme"
    const value_debug: text = "debug"
    const value_dark: text = "dark"

    var c1: Config = Config(props: { key_mode: value_debug })
    var c2: Config = c1
    c2.props[key_theme] = value_dark

    const c1_props: map<text, text> = c1.props
    const c2_props: map<text, text> = c2.props
    const map_score: int = (len(c1_props) * 100) + len(c2_props)
    if list_score == 29 and map_score == 102
        return 0
    end
    return 1
end