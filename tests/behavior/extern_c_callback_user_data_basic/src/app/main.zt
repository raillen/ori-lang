namespace app.main

public var cleanup_log: int = 0

extern c
    attr name("zt_ffi_apply_i64_user_data")
    func apply_i64_user_data(value: int, user_data: int, callback: func(int, int) -> int) -> int
end

func record_cleanup(value: int)
    cleanup_log = cleanup_log + value
end

func add_user_data(value: int, user_data: int) -> int
    using token = user_data then record_cleanup(token)
    return value + user_data
end

public func main() -> int
    cleanup_log = 0
    if apply_i64_user_data(40, 2, add_user_data) != 42
        return 1
    end
    if cleanup_log != 2
        return 1
    end
    return 0
end
