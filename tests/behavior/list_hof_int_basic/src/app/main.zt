namespace app.main

import std.list as list

func main() -> int
    const factor: int = 2
    const values: list<int> = [1, 2, 3, 4, 5]
    const doubled: list<int> = list.map(values, func(value: int) => value * factor)
    const large: list<int> = list.filter(doubled, func(value: int) => value > 5)
    const total: int = list.reduce(large, 0, func(acc: int, value: int) => acc + value)
    const found: optional<int> = list.find(values, func(value: int) => value > 3)
    const sorted_desc: list<int> = list.sort_by(values, func(value: int) => 0 - value)

    if len(doubled) != 5 or doubled[0] != 2 or doubled[4] != 10
        return 1
    end
    if len(large) != 3 or large[0] != 6
        return 2
    end
    if total != 24
        return 3
    end
    if found.or(0) != 4
        return 4
    end
    if sorted_desc[0] != 5 or sorted_desc[4] != 1
        return 10
    end
    if list.any(values, func(value: int) => value == 5) == false
        return 5
    end
    if list.any(values, func(value: int) => value == 9)
        return 6
    end
    if list.all(values, func(value: int) => value > 0) == false
        return 7
    end
    if list.all(values, func(value: int) => value < 4)
        return 8
    end
    if list.count(values, func(value: int) => value > 2) != 3
        return 9
    end

    return 0
end
