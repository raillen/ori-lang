namespace app.main

import std.list as list
import std.map as map

func check_int_text_maps() -> result<void, core.Error>
    const key_a: int = 1
    const key_b: int = 2
    const key_c: int = 3
    const key_d: int = 4
    const empty_text: text = ""

    const red: text = "red"
    const blue: text = "blue"
    const green: text = "green"
    const amber: text = "amber"
    const black: text = "black"

    const base: map<int, text> = { key_a: red, key_b: blue }
    const added: map<int, text> = map.set(base, key_c, green)
    if len(base) != 2 or len(added) != 3
        return error("map<int,text>.set should return a changed copy")
    end
    if map.contains(added, key_c) == false or len(map.get(added, key_c).or(empty_text)) != 5
        return error("map<int,text>.get/contains should use int keys")
    end

    const removed: map<int, text> = map.remove(added, key_a)
    if len(removed) != 2 or map.contains(removed, key_a)
        return error("map<int,text>.remove should remove int keys")
    end

    const keys: list<int> = map.keys(removed)
    const values: list<text> = map.values(removed)
    if len(keys) != 2 or list.contains(keys, key_b) == false or list.contains(keys, key_c) == false
        return error("map<int,text>.keys should return list<int>")
    end
    if len(values) != 2 or list.contains(values, blue) == false or list.contains(values, green) == false
        return error("map<int,text>.values should return list<text>")
    end

    const override: map<int, text> = { key_b: amber, key_d: black }
    const merged: map<int, text> = map.merge(base, override)
    if len(merged) != 3
        return error("map<int,text>.merge should combine both maps")
    end
    if len(merged[key_b]) != 5
        return error("map<int,text>.merge should let the right map override")
    end

    return success()
end

func check_text_int_maps() -> result<void, core.Error>
    const key_alpha: text = "alpha"
    const key_beta: text = "beta"
    const key_gamma: text = "gamma"
    const key_delta: text = "delta"

    const base: map<text, int> = { key_alpha: 10, key_beta: 20 }
    const added: map<text, int> = map.set(base, key_gamma, 30)
    if len(base) != 2 or len(added) != 3
        return error("map<text,int>.set should return a changed copy")
    end
    if map.has_key(added, key_gamma) == false or map.get(added, key_gamma).or(0) != 30
        return error("map<text,int>.get/has_key should use text keys")
    end

    const removed: map<text, int> = map.remove(added, key_alpha)
    if len(removed) != 2 or map.contains(removed, key_alpha)
        return error("map<text,int>.remove should remove text keys")
    end

    const keys: list<text> = map.keys(removed)
    const values: list<int> = map.values(removed)
    if len(keys) != 2 or list.contains(keys, key_beta) == false or list.contains(keys, key_gamma) == false
        return error("map<text,int>.keys should return list<text>")
    end
    if len(values) != 2 or list.contains(values, 20) == false or list.contains(values, 30) == false
        return error("map<text,int>.values should return list<int>")
    end

    const override: map<text, int> = { key_beta: 200, key_delta: 40 }
    const merged: map<text, int> = map.merge(base, override)
    if len(merged) != 3 or merged[key_beta] != 200
        return error("map<text,int>.merge should combine maps and override right-hand keys")
    end

    return success()
end

func main() -> result<void, core.Error>
    check_int_text_maps()?
    check_text_int_maps()?
    return success()
end
