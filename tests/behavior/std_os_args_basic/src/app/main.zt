namespace app.main

import std.os as os

func main() -> result<void, core.Error>
    const values: list<text> = os.args()

    if len(values) < 1
        return error("std.os.args should include at least argv[0]")
    end

    if len(values[0]) == 0
        return error("std.os.args returned empty argv[0]")
    end

    if len(values) == 1
        return success()
    end

    if len(values) != 4
        return error("std.os.args should include argv[0] plus forwarded program args")
    end

    if values[1] != "alpha"
        return error("std.os.args did not preserve first forwarded arg")
    end

    if values[2] != "two words"
        return error("std.os.args did not preserve whitespace inside an arg")
    end

    if values[3] != "--literal-flag"
        return error("std.os.args did not preserve a literal flag after --")
    end

    return success()
end
