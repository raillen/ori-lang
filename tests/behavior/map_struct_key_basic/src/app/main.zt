namespace app.main

import std.map as map

struct Flag
    enabled: bool
    weight: int
end

func main() -> int
    var scores: map<Flag, int> = {}
    const first: Flag = Flag(enabled: true, weight: 3)
    const same: Flag = Flag(enabled: true, weight: 3)
    const other: Flag = Flag(enabled: false, weight: 3)

    scores = map.set(scores, first, 7)

    if len(scores) != 1
        return 1
    end
    if map.has_key(scores, same) == false
        return 2
    end
    if map.contains(scores, other)
        return 3
    end

    scores = map.remove(scores, same)
    if len(scores) != 0
        return 4
    end

    return 0
end
