namespace app.main

import std.channels as channels

public func main() -> int
    const empty_text: text = ""
    const channel: channels.Channel<text> = channels.create()
    if channels.receive(channel).is_some()
        return 1
    end

    channels.send(channel, "message")
    const received: optional<text> = channels.receive(channel)
    if received.is_none() or received.or(empty_text) != "message"
        return 2
    end

    channels.close(channel)
    return 0
end
