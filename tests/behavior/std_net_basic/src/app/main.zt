namespace app.main

import std.net as net

func probe_loopback(port: int) -> result<void, net.Error>
    var connection: net.Connection = net.connect("127.0.0.1", port, 1000)?
    if net.is_closed(connection)
        return error(net.Error.Unknown)
    end
    net.write_all(connection, hex bytes "414243")?
    const _received: optional<bytes> = net.read_some(connection, 16)?
    net.close(connection)?
    if net.is_closed(connection) == false
        return error(net.Error.Unknown)
    end
    return success()
end

func main() -> result<void, core.Error>
    match probe_loopback(41234)
        case success():
            return success()
        case error(err):
            const core_err: core.Error = net.to_core_error(err)
            return error(core_err)
    end
end
