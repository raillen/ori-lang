namespace app.main

struct Flag
    enabled: bool
    weight: int
end

func expect_two(flags: list<Flag>) -> int
    return len(flags)
end

func main() -> int
    var flags: list<Flag> = [
        Flag(enabled: true, weight: 2),
        Flag(enabled: false, weight: 5),
    ]

    if expect_two(flags) != 2
        return 1
    end

    if flags[0].enabled != true
        return 2
    end

    if flags[1].weight != 5
        return 3
    end

    const first: Flag = flags[0]
    if first.weight != 2
        return 4
    end

    flags[1] = Flag(enabled: true, weight: 7)

    if flags[1].enabled != true
        return 5
    end

    if flags[1].weight != 7
        return 6
    end

    return 0
end
