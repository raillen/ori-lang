import ori.io as io

func main() {
    let b1 = "Hello".to_bytes()
    let b2 = ", ".to_bytes()
    let b3 = "World!".to_bytes()
    
    // length
    let len = b1.len()
    io.print("Length of b1: " + len.to_string())

    // concat
    let combined = b1.concat(b2).concat(b3)
    io.print("Combined bytes length: " + combined.len().to_string())
    
    // decode back to string
    match combined.decode_utf8() {
        Ok(s) => io.print("Decoded string: " + s),
        Err(e) => io.print("Decode failed: " + e)
    }

    // to_hex and from_hex
    let hex = b1.to_hex()
    io.print("Hex of b1: " + hex)
    
    match hex.from_bytes() { // testing string extension `from_bytes` equivalent to bytes.from_hex since hex string is not a byte array... wait.
        Ok(b) => io.print("From bytes succeeded"),
        Err(e) => io.print("From bytes failed")
    }

    // test bytes.from_hex
    match "48656c6c6f".from_hex() {
        Ok(b) => {
            let back = b.decode_utf8().unwrap()
            io.print("From hex decoded: " + back)
        },
        Err(e) => io.print("Hex decode failed")
    }

    // slice
    let sliced = combined.slice(0, 5)
    io.print("Sliced decoded: " + sliced.decode_utf8().unwrap())

    // get
    let first_byte = b1.get(0)
    io.print("First byte: " + first_byte.to_string())
}
