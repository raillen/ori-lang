module test.game_simple

import ori.math.vec2 as vec2
import ori.math as math

// Shape structs
struct Rectangle
    x: float
    y: float
    width: float
    height: float
end

struct Circle
    x: float
    y: float
    radius: float
end

// Collision functions
rects_collide(a: Rectangle, b: Rectangle) -> bool
    return a.x < b.x + b.width
       and a.x + a.width > b.x
       and a.y < b.y + b.height
       and a.y + a.height > b.y
end

point_in_rect(point: vec2.Vec2, rect: Rectangle) -> bool
    return point.x >= rect.x and point.x <= rect.x + rect.width
       and point.y >= rect.y and point.y <= rect.y + rect.height
end

circles_collide(a: Circle, b: Circle) -> bool
    const dx: float = a.x - b.x
    const dy: float = a.y - b.y
    const dist: float = a.radius + b.radius
    return dx * dx + dy * dy <= dist * dist
end

// Test functions
test_rectangles() -> void
    const a: Rectangle = Rectangle { x: 0.0, y: 0.0, width: 10.0, height: 10.0 }
    const b: Rectangle = Rectangle { x: 5.0, y: 5.0, width: 10.0, height: 10.0 }
    const c: Rectangle = Rectangle { x: 20.0, y: 20.0, width: 10.0, height: 10.0 }

    assert(rects_collide(a, b))
    assert(not rects_collide(a, c))
end

test_point_in_rect() -> void
    const rect: Rectangle = Rectangle { x: 0.0, y: 0.0, width: 10.0, height: 10.0 }
    const inside: vec2.Vec2 = vec2.Vec2 {x: 5.0, y: 5.0}
    const outside: vec2.Vec2 = vec2.Vec2 {x: 15.0, y: 15.0}

    assert(point_in_rect(inside, rect))
    assert(not point_in_rect(outside, rect))
end

test_circles() -> void
    const a: Circle = Circle { x: 0.0, y: 0.0, radius: 5.0 }
    const b: Circle = Circle { x: 8.0, y: 0.0, radius: 5.0 }
    const c: Circle = Circle { x: 20.0, y: 0.0, radius: 5.0 }

    assert(circles_collide(a, b))
    assert(not circles_collide(a, c))
end

test_vec2_operations() -> void
    const a: vec2.Vec2 = vec2.Vec2 {x: 1.0, y: 2.0}
    const b: vec2.Vec2 = vec2.Vec2 {x: 3.0, y: 4.0}

    const sum: vec2.Vec2 = a + b
    assert(sum.x == 4.0)
    assert(sum.y == 6.0)

    const diff: vec2.Vec2 = b - a
    assert(diff.x == 2.0)
    assert(diff.y == 2.0)

    const d: float = vec2.dot(a, b)
    assert(d == 11.0)
end
