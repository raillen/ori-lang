-- Ori project file
-- This file defines the project structure and dependencies.

name = "my-project"
version = "0.1.0"
manifest = 1
kind = "app"
entry = "examples/hello_world.orl"

[source]
root = "examples"
root_namespace = "app"

[docs]
paths = ["docs/api"]
mode = "sidecar-first"
require_public = "off"

[dependencies]
-- ori add <package> to add dependencies
