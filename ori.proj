-- Monorepo language checkout is not a typical user app.
-- Entry points for smoke live under examples/ as mini-projects.

manifest = 1
name = "ori-lang"
version = "0.3.1"
kind = "app"
entry = "examples/hello/main.orl"

[source]
root_namespace = "app"

[docs]
paths = ["docs"]
mode = "sidecar-first"
require_public = "off"
