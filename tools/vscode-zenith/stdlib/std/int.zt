namespace std.int

extern c
    public func zt_int_to_float(value: int) -> float
    public func zt_int_to_text(value: int) -> text
    public func zt_int_parse(value: text) -> optional<int>
end

public func to_float(value: int) -> float
    return int.zt_int_to_float(value)
end

public func to_text(value: int) -> text
    return int.zt_int_to_text(value)
end

public func parse(value: text) -> optional<int>
    return int.zt_int_parse(value)
end
