#!/usr/bin/env bash
# Scaffold a resource: controller (index/new/create), views, routes (APP8).
# Run from app root (ori.proj present).
# Usage: generate-scaffold <resource>
# Example: generate-scaffold notes

set -euo pipefail

NAME="${1:-}"
if [[ -z "$NAME" ]]; then
  echo "usage: $0 <resource_name>" >&2
  exit 1
fi
if [[ ! -f ori.proj ]]; then
  echo "error: run from app root (ori.proj missing)" >&2
  exit 1
fi

RES="$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_]//g')"
if [[ -z "$RES" ]]; then
  echo "error: invalid name" >&2
  exit 1
fi
TITLE="$(python3 -c "s='$RES'; print(s.replace('_',' ').title())")"
SING="$(python3 -c "s='$RES'; print(s[:-1] if s.endswith('s') and len(s)>1 else s)")"

CTRL="app/controllers/${RES}.orl"
VIEW_DIR="views/${RES}"
ROUTES="config/routes.orl"

if [[ -e "$CTRL" ]]; then
  echo "error: already exists: $CTRL" >&2
  exit 1
fi

mkdir -p app/controllers "$VIEW_DIR"

cat > "$CTRL" <<EOF
module app.controllers.${RES}

-- Scaffolded resource (in-memory list). Replace store with domain/DB later.

import app.application = app
import web = web
import web_app = wa
import templates = tpl
import ori.list = lists
import ori.map = maps
import ori.string = str

var ITEMS: list[string] = []

public index(req: web.Request) -> web.ActionResult
    var d: tpl.Data = tpl.empty_data()
    tpl.set_value(d, "title", "${TITLE}")
    tpl.set_list(d, "items", ITEMS)
    if lists.len(ITEMS) == 0
        tpl.set_value(d, "items_empty", "true")
    else
        tpl.set_value(d, "items_empty", "false")
    end
    return app.render("${RES}/index", req, d)
end

public new_form(req: web.Request) -> web.ActionResult
    var d: tpl.Data = tpl.empty_data()
    tpl.set_value(d, "title", "New ${TITLE}")
    tpl.set_value(d, "csrf_field", wa.csrf_field(req))
    return app.render("${RES}/new", req, d)
end

public create(req: web.Request) -> web.ActionResult
    const form: map[string, string] = web.form_body(req)
    var text: string = ""
    if some(t) = maps.try_get(form, "title")
        text = str.trim(t)
    end
    if str.len(text) == 0
        app.error_flash(req, "Title is required.")
        return app.redirect("/${RES}/new")
    end
    lists.push(ITEMS, text)
    app.notice(req, "${TITLE} created.")
    web.audit("${RES}.create", text)
    return app.redirect("/${RES}")
end
EOF

cat > "$VIEW_DIR/index.orix" <<EOF
@{ layout "layouts/app" }
@{ assign title = "${TITLE}" }
<section class="card">
  <h1>${TITLE}</h1>
  <p><a href="/${RES}/new">New ${SING}</a></p>
  <ul>
  @{ for i, item in items }
    <li><strong>@{ i }</strong> · @{ item }</li>
  @{ end }
  @{ if items_empty }
    <li class="muted">No items yet.</li>
  @{ end }
  </ul>
</section>
@{ end }
EOF

cat > "$VIEW_DIR/new.orix" <<EOF
@{ layout "layouts/app" }
@{ assign title = "New ${TITLE}" }
<section class="card">
  <h1>New ${SING}</h1>
  <form method="post" action="/${RES}">
    @{ csrf_field |> raw }
    <label>Title<br>
      <input type="text" name="title" required autocomplete="off">
    </label>
    <p style="margin-top:0.75rem"><button type="submit">Create</button></p>
  </form>
  <p><a href="/${RES}">Back</a></p>
</section>
@{ end }
EOF

python3 - "$ROUTES" "$RES" <<'PY'
import sys
path, res = sys.argv[1], sys.argv[2]
lines = open(path).read().splitlines()
import_line = f"import app.controllers.{res} = {res}"
if not any(import_line in L for L in lines):
    last_import = max(i for i, L in enumerate(lines) if L.startswith("import "))
    lines.insert(last_import + 1, import_line)

routes = [
    f'    web.get(a, "/{res}", {res}.index)',
    f'    web.get(a, "/{res}/new", {res}.new_form)',
    f'    web.post(a, "/{res}", {res}.create)',
]
# insert before closing end of draw
out = []
in_draw = False
inserted = False
for line in lines:
    if line.strip().startswith("public draw"):
        in_draw = True
    if in_draw and line.strip() == "end" and not inserted:
        for r in routes:
            if r not in lines:
                out.append(r)
        inserted = True
        in_draw = False
    out.append(line)
open(path, "w").write("\n".join(out) + "\n")
print(f"updated {path}")
PY

echo "created $CTRL"
echo "created $VIEW_DIR/index.orix"
echo "created $VIEW_DIR/new.orix"
echo "routes: GET /${RES}, GET /${RES}/new, POST /${RES}"
echo "run: ori check main.orl"
