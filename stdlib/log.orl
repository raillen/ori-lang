namespace ori.log

import ori.io as io

public func info(message: string)
    io.println(ori.string.concat("[info] ", message))
end

public func warn(message: string)
    io.println(ori.string.concat("[warn] ", message))
end

public func error_message(message: string)
    io.eprintln(ori.string.concat("[error] ", message))
end

public func debug(message: string)
    io.println(ori.string.concat("[debug] ", message))
end
