module ori.args

import ori.os = os

public all() -> list[string]
    return os.args()
end

public count() -> int
    return ori.list.len(os.args())
end

public get_or(index: int, fallback: string) -> string
    if some(value) = ori.list.try_get(os.args(), index)
        return value
    end
    return fallback
end

public program_name_or(fallback: string) -> string
    return get_or(0, fallback)
end
