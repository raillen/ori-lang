namespace std.jobs

public struct Job<T>
    handle: int
end

extern c
    public func zt_job_spawn_i64(thunk: func() -> int) -> int
    public func zt_job_spawn_i64_arg(worker: func(int) -> int, value: int) -> int
    public func zt_job_join_i64(handle: int) -> int
    public func zt_job_spawn_text(thunk: func() -> text) -> int
    public func zt_job_spawn_text_arg(worker: func(text) -> text, value: text) -> int
    public func zt_job_join_text(handle: int) -> text
end
