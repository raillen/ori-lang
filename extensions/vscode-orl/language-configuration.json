{
  "comments": {
    "lineComment": "--",
    "blockComment": [ "--|", "|--" ]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "<", "close": ">", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:if|else|elif|while|for|struct|enum|trait|apply|use|implement|using|match|extern)\\b.*$|^\\s*(?:(?:public|async|mut)\\s+)+[A-Za-z_][A-Za-z0-9_]*.*$|^\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^>]*>)?\\s*\\(\\s*\\)\\s*(?:->\\s*\\S+)?\\s*(?:where\\b.*)?$|^\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^>]*>)?\\s*\\(\\s*self\\b[^)]*\\)\\s*(?:->\\s*\\S+)?\\s*(?:where\\b.*)?$|^\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^>]*>)?\\s*\\([^)]*:[^)]*\\)\\s*(?:->\\s*\\S+)?\\s*(?:where\\b.*)?$|^\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^>]*>)?\\s*\\([^)]*\\)\\s*->\\s*\\S+.*$",
    "decreaseIndentPattern": "^\\s*(end|else|elif)\\b.*$"
  }
}
